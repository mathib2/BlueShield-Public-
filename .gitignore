# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs (generated at runtime)
blueshield/logs/*.json
!blueshield/logs/__init__.py
!blueshield/logs/logger.py

# Config (user-specific runtime config)
blueshield/config/blueshield_config.json

# Extracted PPTX assets (build artifacts)
pptx_extract/

# Claude
.claude/

# Captures (runtime PCAP / Crackle output)
captures/
*.pcap
*.pcapng

# Crypto material (Ed25519 keypair generated per-install — never commit)
keys/

# Heatmap survey state (per-deployment, not source)
blueshield/scanner/heatmap.json
blueshield/scanner/heatmap.json.tmp

# Personal scratch / test scripts (not part of the product)
tools/test_*.py
tools/probe_*.py
tools/*.tmp

# Firmware binaries (download from upstream — Sniffle, ButteRFly, etc.)
tools/*.hex
tools/*.zip
tools/*.bin
tools/*.uf2

# Random external .deb packages stashed in the workspace
*.deb

# Unrelated personal docs accidentally placed in the workspace
NCL_Spring_Team_2026/

# Backup files
*.bak
*.orig

# Local sandbox state
.scheduled_tasks.lock
memory.lock
